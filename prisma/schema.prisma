generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Admin{
id String @id @default(uuid())
clerkId         String? @unique
firstName       String
lastName        String
role AdminRole @default(SALES)
}
model Dealer{
id String @id @default(uuid()) 
clerkId         String?         @unique
companyName     String
tradingName     String?
email           String?         @unique
phone           String?
logo            String?
listings        Vehicle[]
inquiries       Inquiry[]
createdAt       DateTime        @default(now())
updatedAt       DateTime        @updatedAt
}
model User{
id String @id @default(uuid())
firstName  String
lastName   String
clerkid String @unique
favorites   Favorite[]
inquiries   Inquiry[]
createdAt  DateTime @default(now())
updatedAt  DateTime @updatedAt
}

model Vehicle {
  id              String          @id @default(uuid())
  dealerId        String
  dealer          Dealer          @relation(fields: [dealerId], references: [id])
  make            String
  model           String
  variant         String?
  year            Int
  mileage         Int
  price           Decimal         @db.Decimal(12,2)
  fuelType        FuelType
  transmission    Transmission
  bodyType        BodyType
  colour          String?
  description     String?         @db.Text
  status          ListingStatus   @default(ACTIVE)
  images          VehicleImage[]
  favorites       Favorite[]
  inquiries       Inquiry[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model VehicleImage {
  id          String      @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url         String
  position    Int         @default(0)
  createdAt   DateTime    @default(now())
}

model Favorite {
  id          String      @id @default(uuid())
  userId      String
  vehicleId   String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  @@unique([userId, vehicleId])
}

model Inquiry {
  id          String      @id @default(uuid())
  userId      String
  dealerId    String
  vehicleId   String
  message     String      @db.Text
  user        User        @relation(fields: [userId], references: [id])
  dealer      Dealer      @relation(fields: [dealerId], references: [id])
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime    @default(now())
}
enum AdminRole {
  ADMIN
  TRAINER
  SALES
  MANAGER
  ASSISTANT
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  REMOVED
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  COUPE
  CONVERTIBLE
  BAKKIE
  VAN
}