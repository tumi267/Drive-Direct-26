generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Admin{
id String @id @default(uuid())
clerkId         String? @unique
firstName       String
lastName        String
role AdminRole @default(SALES)
}
model Dealer {
  id String @id @default(uuid())
  companyName String
  tradingName String?
  email String?
  phone String?
  listings Vehicle[]
  users DealerUser[]
  tickets         Ticket[]
  verificationStatus DealerVerificationStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model DealerUser {
  id String @id @default(uuid())

  clerkId String @unique

  firstName String
  lastName String
  status DealerUserStatus @default(ACTIVE)
  role DealerRole

  dealerId String
  dealer Dealer @relation(fields:[dealerId], references:[id])
  tickets         Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User{
id String @id @default(uuid())
firstName  String
lastName   String
clerkid String @unique
favorites   Favorite[]
inquiries   Inquiry[]
role    UserRole @default(USER)

createdAt  DateTime @default(now())
updatedAt  DateTime @updatedAt
}

model Vehicle {
  id              String          @id @default(uuid())
  dealerId        String
  dealer          Dealer          @relation(fields: [dealerId], references: [id])
  make            String
  model           String
  variant         String?
  year            Int
  mileage         Int
  price           Decimal         @db.Decimal(12,2)
  fuelType        FuelType
  transmission    Transmission
  bodyType        BodyType
  colour          String?
  description     String?         @db.Text
  status          ListingStatus   @default(DRAFT)
  images          VehicleImage[]
  favorites       Favorite[]
  inquiries       Inquiry[]
  tickets         Ticket[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model VehicleImage {
  id          String      @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url         String
  publicId    String
  position    Int         @default(0)
  imageType  VehicleImageType?
  createdAt   DateTime    @default(now())
}

model Favorite {
  id          String      @id @default(uuid())
  userId      String
  vehicleId   String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  @@unique([userId, vehicleId])
}

model Inquiry {
  id          String @id @default(uuid())
  userId      String
  dealerId    String
  vehicleId   String
  message     String @db.Text
  user        User @relation(fields: [userId], references: [id])
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime @default(now())
}

model Ticket {
  id           String   @id @default(uuid())

  reference    String   @unique

  type         TicketType

  status       TicketStatus

  department   Department

  vehicleId    String
  vehicle      Vehicle @relation(fields: [vehicleId], references: [id])

  dealerId     String
  dealer       Dealer  @relation(fields: [dealerId], references: [id])

  claimedById  String?
  claimedBy    DealerUser? @relation(fields: [claimedById], references: [id])

  firstName    String
  lastName     String
  email        String
  phone        String?

  message      String   @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TicketType {
  VEHICLE_ENQUIRY
}
enum Department {
  SALES
  FINANCE
  MANAGEMENT
  OPERATIONS
}
enum TicketStatus {
  NEW_ENQUIRY
  ASSIGNED_TO_SALES
  CONTACTED
  QUOTE_IN_PROGRESS
  FINANCE_REVIEW
  AWAITING_MANAGEMENT_APPROVAL
  QUOTE_SENT
  AWAITING_CUSTOMER_DECISION
  ACCEPTED
  FINANCE_PROCESSING
  READY_FOR_DELIVERY
  DELIVERED
  CLOSED
  CANCELLED
  ARCHIVED
}
enum AdminRole {
  ADMIN
  TRAINER
  SALES
  MANAGER
  ASSISTANT
}

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SOLD
  REMOVED
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  COUPE
  CONVERTIBLE
  BAKKIE
  VAN
}

enum UserRole {
  USER
  DEALER
  ADMIN
}
enum DealerRole {
  OWNER
  MANAGER
  SALES
}
enum DealerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}
enum DealerUserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}
enum VehicleImageType {
  EXTERIOR_FRONT
  EXTERIOR_REAR
  INTERIOR
  TRUNK
  ENGINE
  PROMO
  OTHER
}